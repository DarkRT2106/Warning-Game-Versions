def get_random_message():
    texts = [msg[0] for msg in warning_messages]
    weights = [msg[1] for msg in warning_messages]

    return random.choices(
        texts,
        weights=weights,
        k=1
    )[0]


def random_warning():
    msg = get_random_message()
    add_message(msg)

    # 🎵 кастомный звук для самого редкого сообщения
    if "0.6%" in msg:
        rare_sound.play()

    root.after(
        random.randint(5000, 15000),
        random_warning
    )






