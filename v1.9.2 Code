def add_message(text):
    time = datetime.now().strftime("%H:%M:%S")
    full_text = f"[{time}] {text}\n"

    chat.config(state="normal")

    # сразу добавляем строку, но пустую
    chat.insert("end", "\n")
    line_start = chat.index("end-1c")

    chat.config(state="disabled")


    i = 0



    def write():

        nonlocal i

        if i < len(full_text):
            chat.config(state="normal")

            chat.delete(line_start, f"{line_start} lineend")
            chat.insert(line_start, full_text[:i + 1])

            chat.config(state="disabled")

            i += 1
            root.after(10, write)

        else:
            chat.config(state="normal")
            chat.delete(line_start, f"{line_start} lineend")
            chat.insert(line_start, full_text)
            chat.config(state="disabled")



    write()


    chat.config(state="disabled")
    chat.bind("<Button-1>", lambda e: "break")
    chat.bind("<B1-Motion>", lambda e: "break")
    chat.bind("<Double-Button-1>", lambda e: "break")
    chat.bind("<Triple-Button-1>", lambda e: "break")

    global rarest_found, game_started

    if game_started and "%" in text:
        try:
            percent = float(text.split("%")[0])
        except:
            percent = 999

        if rarest_found is None or percent < rarest_found[0]:
            rarest_found = (percent, text)
            rare_label.config(text=f"🏆 Самое редкое: {percent}%")

