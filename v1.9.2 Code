def toggle_music():
    global music_enabled

    if music_enabled:
        pygame.mixer.music.pause()
        music_button.config(text="🔇")
        music_enabled = False
    else:
        pygame.mixer.music.unpause()
        music_button.config(text="🔊")
        music_enabled = True

