def add_message(text):
    global rarest_found, game_started
    global money



    time = datetime.now().strftime("%H:%M:%S")
    full_text = f"[{time}] {text}\n"

    chat.config(state="normal")

    # сразу добавляем строку, но пустую
    chat.insert("end", "\n")
    line_start = chat.index("end-1c")

    chat.config(state="disabled")

    chat.config(state="normal")
    chat.insert(tk.END, full_text)
    if chat.yview()[1] > 0.95:
        chat.see(tk.END)
    chat.config(state="disabled")


    chat.config(state="disabled")
    chat.bind("<Button-1>", lambda e: "break")
    chat.bind("<B1-Motion>", lambda e: "break")
    chat.bind("<Double-Button-1>", lambda e: "break")
    chat.bind("<Triple-Button-1>", lambda e: "break")
    if game_started:
        old_count = len(found_messages)

        found_messages.add(text)

        if len(found_messages) > old_count:
            collection_label.config(
                text=f"📚 Собрано: {len(found_messages)}/{len(warning_messages)}"
            )
        save_game()



    if game_started and "%" in text:
        try:
            percent = float(text.split("%")[0])
        except:
            percent = 999

        reward = 0

        if percent >= 80:
            reward = 1
        elif percent >= 70:
            reward = 2
        elif percent >= 50:
            reward = 3
        elif percent >= 30:
            reward = 5
        elif percent >= 10:
            reward = 10
        elif percent >= 5:
            reward = 20
        elif percent >= 4:
            reward = 30
        elif percent >= 2:
            reward = 40
        elif percent >= 1:
            reward = 70
        elif percent >= 0.6:
            reward = 100
        elif percent >= 0.4:
            reward = 200
        else:
            reward = 500

        money += reward

        money_label.config(
            text=f"💰 Монеты: {money}"
        )

        if rarest_found is None or percent < rarest_found[0]:
            rarest_found = (percent, text)
            rare_label.config(text=f"🏆 Самое редкое: {percent}%")



            save_game()

