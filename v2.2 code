def load_game():
    global rarest_found, found_messages, money
    global speed_level, luck_level






    if not os.path.exists(SAVE_FILE):
        return

    try:
        with open(SAVE_FILE, "r", encoding="utf-8") as f:
            data = json.load(f)

        found_messages = set(data.get("found_messages", []))

        valid_messages = {msg[0] for msg in warning_messages}

        found_messages = {
            msg for msg in found_messages
            if msg in valid_messages
        }

        collection_label.config(
            text=f"Собрано: {len(found_messages)}/{len(warning_messages)}"
        )

        rarest_percent = data.get("rarest_percent")

        if rarest_percent is not None:
            rarest_found = (rarest_percent, "")

            rare_label.config(
                text=f"🏆 Самое редкое: {rarest_percent}%"
            )

        money = data.get("money", 0)
        speed_level = data.get("speed_level", 0)
        luck_level = data.get("luck_level", 0)

        money_label.config(
            text=f"💰 Монеты: {money}"
        )

    except Exception as e:
        print("Ошибка загрузки:", e)

