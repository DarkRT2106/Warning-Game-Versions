def save_game():
    try:
        data = {


            "speed_level": speed_level,
            "luck_level": luck_level,
            "money": money,
            "found_messages": list(found_messages),
            "rarest_percent": (
                rarest_found[0]
                if rarest_found is not None
                else None
            )
        }

        with open(SAVE_FILE, "w", encoding="utf-8") as f:
            json.dump(
                data,
                f,
                ensure_ascii=False,
                indent=4
            )

    except Exception as e:
        print("Ошибка сохранения:", e)



def get_random_message():
    texts = [msg[0] for msg in warning_messages]
    weights = []

    for text, chance in warning_messages:

        if chance < 10:
            chance *= (1 + luck_level * 0.02)

        weights.append(chance)

    return random.choices(
        texts,
        weights=weights,
        k=1
    )[0]




def random_warning():
    msg = get_random_message()
    add_message(msg)

    # 🎵 кастомный звук для самого редкого сообщения
    if "0." in msg:
        rare_sound.play()

    delay = random.randint(
        max(1000, 5000 - speed_level * 1000),
        max(3000, 15000 - speed_level * 1000)
    )

    root.after(delay, random_warning)






# Первое уведомление через 5 секунд
